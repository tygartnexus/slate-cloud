{
  "name": "slate-cloud-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "node -e \"require('node:fs').rmSync('.next/types',{recursive:true,force:true})\" && next typegen && tsc --noEmit",

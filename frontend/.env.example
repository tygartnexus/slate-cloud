SLATE_API_URL=http://localhost:8000
NEXT_PUBLIC_SLATE_REPO_URL=https://github.com/tygartnexus/slate

# Clerk — get from dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key
CLERK_SECRET_KEY=replace-with-clerk-secret-key

# Local Playwright-only fixture auth. Leave unset in hosted deployments.
# SLATE_E2E_AUTH_BYPASS=unsafe-local-only
# NEXT_PUBLIC_SLATE_E2E_AUTH_BYPASS=unsafe-local-only
# SLATE_E2E_API_FIXTURE=true
# SLATE_E2E_AUTH_SECRET=replace-with-32-plus-char-random-local-secret
# SLATE_ALLOW_LOCAL_E2E_BUILD=true
# PLAYWRIGHT_TEST=1

# development, test, or production. Production fails closed unless DATABASE_URL
# points to a non-SQLite database.
APP_ENV=development
DATABASE_URL=sqlite:///./slate_cloud_local.db

# Clerk JWT public key (PEM). Get from Clerk dashboard -> API Keys -> JWT public key
CLERK_JWT_PUBLIC_KEY=

# Optional Clerk JWT claim checks. Configure these for hosted deployments.
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
CLERK_JWT_AUTHORIZED_PARTIES=

# Comma-separated frontend origins allowed to call the backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Max JSON verdict payload persisted by Slate Cloud, in bytes.
VERDICT_MAX_PAYLOAD_BYTES=524288
